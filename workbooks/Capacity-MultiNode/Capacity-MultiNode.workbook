          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "parameters": [
                {
                  "id": "node-trends-time-range-mc-perf",
                  "version": "KqlParameterItem/1.0",
                  "name": "NodeTrendsTimeRange",
                  "label": "Historic Time Range",
                  "type": 4,
                  "description": "Time range for the Storage & Network performance charts below.",
                  "isRequired": true,
                  "typeSettings": {
                    "selectableValues": [
                      {
                        "durationMs": 1800000
                      },
                      {
