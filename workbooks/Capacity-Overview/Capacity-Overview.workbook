                    }
                  }
                ],
                "rowLimit": 2000,
                "filter": true,
                "labelSettings": [
                  {
                    "columnId": "ClusterName",
                    "label": "Cluster"
                  },
                  {
                    "columnId": "status",
                    "label": "Status"
                  },
                  {
                    "columnId": "nodeCount",
                    "label": "Machines"
                  },
                  {
                    "columnId": "pCPUvCPURatio",
                    "label": "V:P CPU Ratio"
                  },
                  {
                    "columnId": "ratioValue",
                    "label": "V:P CPU Ratio"
                  },
                  {
                    "columnId": "ratioHealthPct",
                    "label": "% of V:P Target"
                  },
                  {
                    "columnId": "workloadMemoryPct",
                    "label": "Workload Memory %"
                  },
                  {
                    "columnId": "memoryUsagePct",
                    "label": "N-1 Memory Risk %"
                  },
                  {
