                    "label": "pCPUs"
                  },
                  {
                    "columnId": "vCPUTotal",
                    "label": "vCPUs"
                  },
                  {
                    "columnId": "physicalMemoryGB",
                    "label": "Physical Memory"
                  },
                  {
                    "columnId": "vmMemoryTotalGB",
                    "label": "Workload Memory"
                  },
                  {
                    "columnId": "vmVCPUTotal",
                    "label": "VM vCPUs"
                  },
                  {
                    "columnId": "aksVCPUTotal",
                    "label": "AKS vCPUs"
                  },
                  {
