                      "thresholdsGrid": [
                        {
                          "operator": ">",
                          "thresholdValue": "0",
                          "representation": "yellow",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  }
                ],
                "labelSettings": [
                  {
                    "columnId": "extensionName",
                    "label": "Extension"
                  }
                ]
              },
              "noDataMessage": "No Arc extension status data found for the nodes in scope.",
              "noDataMessageStyle": 4
            },
            "customWidth": "60",
            "name": "extension-status-table",
            "styleSettings": {
              "margin": "5",
              "padding": "5",
              "maxWidth": "60"
            }
