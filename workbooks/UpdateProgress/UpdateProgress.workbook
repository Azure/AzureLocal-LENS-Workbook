                ]
              },
              "noDataMessage": "No clusters in scope have an update available right now (or none match the filters).",
              "noDataMessageStyle": 4
            },
            "name": "clusters-updates-available"
          },
          {
            "type": 1,
            "content": {
              "json": "## 📜 Update Run History and Error Details\n\nRecent update runs across all clusters. For failed updates, expand the row to see step failure details.\n\n> **Note:** Default filter applied to table below: 'Update State' = 'Failed'. Unresolved Failed runs are always shown regardless of the **Time Range** filter; once a later Succeeded run exists for the same cluster, the older Failed run is hidden."
            },
            "name": "text-update-history"
          },
          {
            "type": 1,
            "content": {
              "json": "📚 **Knowledge:** [Troubleshooting Azure Local Update failures](https://learn.microsoft.com/azure/azure-local/update/update-troubleshooting-23h2#troubleshoot-update-failures)"
            },
            "name": "update-history-knowledge-link"
          },
          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "parameters": [
                {
                  "id": "update-history-time-range",
                  "version": "KqlParameterItem/1.0",
                  "name": "UpdateHistoryTimeRange",
                  "label": "Time Range",
                  "type": 4,
                  "description": "Time window for Succeeded / In-Progress runs. Unresolved Failed runs (i.e. with no later Succeeded run on the same cluster) are always shown regardless of this setting.",
                  "isRequired": true,
                  "value": {
                    "durationMs": 3888000000
                  },
                  "typeSettings": {
                    "selectableValues": [
                      {
                        "durationMs": 86400000
                      },
                      {
                        "durationMs": 172800000
                      },
                      {
                        "durationMs": 604800000
                      },
                      {
                        "durationMs": 2592000000
                      },
                      {
                        "durationMs": 3888000000
                      },
                      {
                        "durationMs": 7776000000
                      },
                      {
                        "durationMs": 15552000000
                      },
                      {
                        "durationMs": 31536000000
                      }
                    ]
                  }
                },
                {
                  "id": "update-history-cluster-filter",
                  "version": "KqlParameterItem/1.0",
                  "name": "UpdateHistoryClusterFilter",
                  "label": "Filter by Cluster Name",
                  "type": 1,
                  "description": "Optional: Filter by cluster name using wildcards. Example: *prod* or *hci*",
                  "isRequired": false,
                  "value": "",
                  "timeContext": {
                    "durationMs": 86400000
                  }
                },
                {
                  "id": "update-history-update-name-filter",
                  "version": "KqlParameterItem/1.0",
                  "name": "UpdateHistoryUpdateNameFilter",
                  "label": "Filter by Update Name",
                  "type": 1,
                  "description": "Optional: Filter by update name using wildcards. Example: *10.2411* or *SBE*",
                  "isRequired": false,
                  "value": "",
                  "timeContext": {
                    "durationMs": 86400000
                  }
                },
                {
                  "id": "update-history-state-filter",
                  "version": "KqlParameterItem/1.0",
                  "name": "UpdateHistoryStateFilter",
                  "label": "Filter by Update State",
                  "type": 2,
                  "isRequired": true,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "showDefault": false
                  },
                  "jsonData": "[\r\n  { \"value\": \"Succeeded\", \"label\": \"Succeeded\" },\r\n  { \"value\": \"Failed\", \"label\": \"Failed\" },\r\n  { \"value\": \"InProgress\", \"label\": \"In Progress\" }\r\n]",
                  "defaultValue": "Failed",
                  "timeContext": {
                    "durationMs": 86400000
                  }
                },
                {
                  "id": "update-history-status-filter",
                  "version": "KqlParameterItem/1.0",
                  "name": "UpdateHistoryStatusFilter",
                  "label": "Filter by Status",
                  "type": 2,
                  "isRequired": true,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "showDefault": false
                  },
                  "jsonData": "[\r\n  { \"value\": \"Success\", \"label\": \"Success\" },\r\n  { \"value\": \"Error\", \"label\": \"Error\" },\r\n  { \"value\": \"Extracted\", \"label\": \"Extracted (Health Check Blocked)\" },\r\n  { \"value\": \"InProgress\", \"label\": \"In Progress\" }\r\n]",
                  "defaultValue": "value::all",
                  "timeContext": {
                    "durationMs": 86400000
                  }
                }
              ],
              "style": "pills",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces"
            },
            "name": "update-history-filters"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "extensibilityresources\r\n| where type == 'microsoft.azurestackhci/clusters/updates/updateruns'\r\n| where '{ResourceGroupFilter}' == '' or resourceGroup matches regex strcat('(?i)', replace_string(replace_string('{ResourceGroupFilter}', '*', '.*'), '?', '.'))\r\n| extend hciClusterName = tostring(split(id, '/')[8])\r\n| join kind=inner (\r\n    resources\r\n    | where type =~ 'microsoft.azurestackhci/clusters'\r\n    | where '{ClusterTagName}' == '' or ('{ClusterTagValue}' != '' and tostring(tags['{ClusterTagName}']) =~ '{ClusterTagValue}')\r\n    | extend hciClusterName = name\r\n    | distinct hciClusterName\r\n) on hciClusterName\r\n| project-away hciClusterName1\r\n| extend updateName = tostring(split(id, '/')[10])\r\n| where '{UpdateHistoryClusterFilter}' == '' or hciClusterName matches regex strcat('(?i)', replace_string(replace_string('{UpdateHistoryClusterFilter}', '*', '.*'), '?', '.'))\r\n| where '{UpdateHistoryUpdateNameFilter}' == '' or updateName matches regex strcat('(?i)', replace_string(replace_string('{UpdateHistoryUpdateNameFilter}', '*', '.*'), '?', '.'))\r\n| extend runName = name\r\n| extend state = tostring(properties.state)\r\n| extend timeStarted = todatetime(properties.timeStarted)\r\n| where todatetime(timeStarted) >= {UpdateHistoryTimeRange:start} or state == 'Failed'\r\n| extend lastUpdatedTime = todatetime(properties.lastUpdatedTime)\r\n| extend duration = tostring(properties.duration)\r\n| extend durationHours = iff(duration contains 'H', toint(extract('([0-9]+)H', 1, duration)), 0)\r\n| extend durationMinutes = iff(duration contains 'M', toint(extract('([0-9]+)M', 1, duration)), 0)\r\n| extend durationSeconds = iff(duration contains 'S', toint(extract('([0-9]+)', 1, extract('([0-9.]+)S', 1, duration))), 0)\r\n| extend durationFormatted = strcat(iff(durationHours > 0, strcat(tostring(durationHours), 'h '), ''), iff(durationMinutes > 0 or durationHours > 0, strcat(tostring(durationMinutes), 'm '), ''), tostring(durationSeconds), 's')\r\n| extend progressObj = properties.progress\r\n| extend progressJson = tostring(properties.progress)\r\n| extend progressStatus = tostring(progressObj.status)\r\n| extend progressDescription = tostring(progressObj.description)\r\n| mv-expand s1 = progressObj.steps\r\n| mv-expand s2 = s1.steps\r\n| mv-expand s3 = s2.steps\r\n| mv-expand s4 = s3.steps\r\n| mv-expand s5 = s4.steps\r\n| mv-expand s6 = iff(array_length(s5.steps) > 0, s5.steps, dynamic([null]))\r\n| mv-expand s7 = iff(isnotnull(s6) and array_length(s6.steps) > 0, s6.steps, dynamic([null]))\r\n| extend e5Msg = tostring(s5.errorMessage), e5Name = tostring(s5.name), e5Status = tostring(s5.status)\r\n| extend e4Msg = tostring(s4.errorMessage), e4Name = tostring(s4.name), e4Status = tostring(s4.status)\r\n| extend e3Msg = tostring(s3.errorMessage), e3Name = tostring(s3.name), e3Status = tostring(s3.status)\r\n| extend e2Msg = tostring(s2.errorMessage), e2Name = tostring(s2.name), e2Status = tostring(s2.status)\r\n| extend e1Msg = tostring(s1.errorMessage), e1Name = tostring(s1.name), e1Status = tostring(s1.status), e1Desc = tostring(s1.description)\r\n| extend e6Msg = iff(isnotnull(s6), tostring(s6.errorMessage), ''), e6Name = iff(isnotnull(s6), tostring(s6.name), ''), e6Status = iff(isnotnull(s6), tostring(s6.status), '')\r\n| extend e7Msg = iff(isnotnull(s7), tostring(s7.errorMessage), ''), e7Name = iff(isnotnull(s7), tostring(s7.name), ''), e7Status = iff(isnotnull(s7), tostring(s7.status), '')\r\n| extend e8Arr = iff(isnotnull(s7), s7.steps, dynamic(null))\r\n| extend e8First = iff(isnotnull(e8Arr) and array_length(e8Arr) > 0, e8Arr[0], dynamic(null))\r\n| extend e8Msg = tostring(e8First.errorMessage), e8Name = tostring(e8First.name), e8Status = tostring(e8First.status)\r\n| extend mvExpandErrMsg = coalesce(iff(strlen(e8Msg) > 0, e8Msg, ''), iff(strlen(e7Msg) > 0, e7Msg, ''), iff(strlen(e6Msg) > 0, e6Msg, ''), iff(strlen(e5Msg) > 0, e5Msg, ''), iff(strlen(e4Msg) > 0, e4Msg, ''), iff(strlen(e3Msg) > 0, e3Msg, ''), iff(strlen(e2Msg) > 0, e2Msg, ''), iff(strlen(e1Msg) > 0, iff(strlen(e1Desc) > strlen(e1Msg), strcat(e1Msg, ' | ', e1Desc), e1Msg), ''))\r\n| extend deepExceptionMsg = extract('raised an exception:................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................', 0, progressJson)\r\n| extend deepestErrMsg = iff(strlen(mvExpandErrMsg) > 10, mvExpandErrMsg, deepExceptionMsg)\r\n| extend errorBasedStep = case(\r\n    deepestErrMsg has 'UpdateSecuredCore', 'Update Secured-core',\r\n    deepestErrMsg has 'CAU' or deepestErrMsg has 'Cluster-Aware', 'CAU Update',\r\n    deepestErrMsg has 'RotateSecrets' or deepestErrMsg has 'Rotate Secrets', 'Rotate Secrets',\r\n    deepestErrMsg has 'MocArb' or deepestErrMsg has 'CliExtensions', 'Update Arc Prerequisites',\r\n    deepestErrMsg has 'certificate rotation', 'Certificate Rotation',\r\n    '')\r\n| extend deepestErrDepth = case(strlen(e8Msg) > 0, 8, strlen(e7Msg) > 0, 7, strlen(e6Msg) > 0, 6, strlen(e5Msg) > 0, 5, strlen(e4Msg) > 0, 4, strlen(e3Msg) > 0, 3, strlen(e2Msg) > 0, 2, strlen(e1Msg) > 0, 1, e8Status == 'Error', 8, e7Status == 'Error', 7, e6Status == 'Error', 6, e5Status == 'Error', 5, e4Status == 'Error', 4, e3Status == 'Error', 3, e2Status == 'Error', 2, e1Status == 'Error', 1, e8Status == 'Failed', 8, e7Status == 'Failed', 7, e6Status == 'Failed', 6, e5Status == 'Failed', 5, e4Status == 'Failed', 4, e3Status == 'Failed', 3, e2Status == 'Failed', 2, e1Status == 'Failed', 1, strlen(errorBasedStep) > 0, 1, 0)\r\n| extend deepestErrStep = case(deepestErrDepth == 8, e8Name, deepestErrDepth == 7, e7Name, deepestErrDepth == 6, e6Name, deepestErrDepth == 5, e5Name, deepestErrDepth == 4, e4Name, deepestErrDepth == 3, e3Name, deepestErrDepth == 2, e2Name, deepestErrDepth == 1, iff(isnotempty(errorBasedStep), errorBasedStep, e1Name), '')\r\n| summarize \r\n    arg_max(deepestErrDepth, deepestErrStep),\r\n    ErrorStepMessage = max(deepestErrMsg),\r\n    state = max(state),\r\n    timeStarted = max(timeStarted),\r\n    lastUpdatedTime = max(lastUpdatedTime),\r\n    durationFormatted = max(durationFormatted),\r\n    progressStatus = max(progressStatus),\r\n    progressDescription = max(progressDescription),\r\n    subscriptionId = max(subscriptionId),\r\n    resourceGroup = max(resourceGroup)\r\n    by hciClusterName, updateName, id\r\n| extend CurrentStep = iff(state == 'Failed', iff(isnotempty(deepestErrStep), deepestErrStep, progressDescription), '')\r\n| extend ErrorMessageClean = replace_string(replace_string(ErrorStepMessage, '\\\\r\\\\n', ' '), '\\\\n', ' ')\r\n| extend ErrorMessageDisplay = iff(strlen(ErrorMessageClean) > 0, ErrorMessageClean, iff(state == 'Failed' and progressStatus == 'Error', 'No ''Error Details'' available - click Update Name link to view in Azure portal', ''))\r\n| extend ErrorMessageTruncated = iff(strlen(ErrorMessageDisplay) > 3000, strcat(substring(ErrorMessageDisplay, 0, 3000), '... (truncated)'), ErrorMessageDisplay)\r\n| where '*' in ({UpdateHistoryStateFilter}) or state in ({UpdateHistoryStateFilter})\r\n| where '*' in ({UpdateHistoryStatusFilter}) or progressStatus in ({UpdateHistoryStatusFilter})\r\n| extend hasErrorDetails = iff(isnotempty(ErrorStepMessage), 1, 0)\r\n| extend sortKey = strcat(tostring(hasErrorDetails), '_', format_datetime(timeStarted, 'yyyy-MM-dd HH:mm:ss'))\r\n| extend clusterResourceId = strcat('/subscriptions/', subscriptionId, '/resourceGroups/', resourceGroup, '/providers/microsoft.azurestackhci/clusters/', hciClusterName)\r\n| extend encodedResourceId = replace_string(replace_string(clusterResourceId, '/', '%2F'), ' ', '%20')\r\n| extend PortalLink = strcat('https://portal.azure.com/#view/Microsoft_AzureStackHCI_PortalExtension/SingleInstanceHistoryDetails.ReactView/resourceId/', encodedResourceId, '/updateName~/null/updateRunName~/null/refresh~/false')\r\n| join kind=leftouter (\r\n    extensibilityresources\r\n    | where type == 'microsoft.azurestackhci/clusters/updates/updateruns'\r\n    | extend _rState = tostring(properties.state)\r\n    | where _rState == 'Succeeded'\r\n    | extend _rCluster = tostring(split(id, '/')[8])\r\n    | extend _rStarted = todatetime(properties.timeStarted)\r\n    | summarize _latestSucceeded = max(_rStarted) by _rCluster\r\n) on $left.hciClusterName == $right._rCluster\r\n| where not(state == 'Failed' and isnotnull(_latestSucceeded) and timeStarted < _latestSucceeded)\r\n| extend _dedup = iff(state == 'Failed', strcat(hciClusterName, '|', updateName), id)\r\n| summarize arg_max(lastUpdatedTime, *) by _dedup\r\n| project-away _dedup\r\n| join kind=leftouter (\r\n    extensibilityresources\r\n    | where type == 'microsoft.azurestackhci/clusters/updatesummaries'\r\n    | extend _hcCluster = tostring(split(id, '/')[8])\r\n    | extend _hcr = array_reverse(properties.healthCheckResult)\r\n    | mv-expand _hc = _hcr\r\n    | where tostring(_hc.status) == 'Failed' and tostring(_hc.severity) == 'Critical'\r\n    | extend _hcLine = strcat('| **', tostring(_hc.severity), '** | ', tostring(_hc.displayName), ' | ', tostring(_hc.targetResourceName), ' | ', tostring(_hc.description), ' |')\r\n    | summarize _hcTable = strcat_array(make_list(_hcLine, 20), '\\n') by _hcCluster\r\n    | extend _hcMarkdown = strcat('\\n\\n## Failed Health Checks (from Update Summaries)\\n\\n| Severity | Check Name | Target | Description |\\n|:--|:--|:--|:--|\\n', _hcTable, '\\n\\n📚 [Troubleshoot Azure Local Updates](https://learn.microsoft.com/azure/azure-local/update/update-troubleshooting-23h2)')\r\n    | project _hcCluster, _hcMarkdown\r\n) on $left.hciClusterName == $right._hcCluster\r\n| extend ErrorMessageBlade = iff(strlen(ErrorMessageDisplay) > 0, strcat('## Error Details\\n\\n**Cluster:** ', hciClusterName, '\\n\\n**Update:** ', updateName, '\\n\\n**Current Step:** ', CurrentStep, '\\n\\n---\\n\\n', ErrorMessageDisplay, coalesce(_hcMarkdown, '')), '')\r\n| extend ClusterLink = strcat('https://portal.azure.com/#@/resource', clusterResourceId, '/overview')\r\n| project ClusterName = hciClusterName, ClusterLink, UpdateName = updateName, PortalLink, State = state, Status = progressStatus, CurrentStep, ErrorMessage = ErrorMessageTruncated, ErrorMessageFull = ErrorMessageDisplay, ErrorMessageBlade, Duration = durationFormatted, TimeStarted = timeStarted, LastUpdated = lastUpdatedTime\r\n| order by TimeStarted desc",
              "size": 0,
              "showAnalytics": true,
              "showRefreshButton": true,
              "showExportToExcel": true,
              "noDataMessage": "No update runs match the current filters. Try widening the 'Time Range' parameter above, or change the 'Filter by Update State' / 'Filter by Status' selections. Note: unresolved Failed runs are surfaced regardless of time range; once a later Succeeded run exists for the same cluster, the older Failed run is hidden.",
              "noDataMessageStyle": 4,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
